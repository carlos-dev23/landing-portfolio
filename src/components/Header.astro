---
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full border-b border-border-dark bg-background-dark/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary">terminal</span>
      <span class="text-lg font-bold tracking-tight text-white">Dev Carlos Torres</span>
    </div>

    <button id="openContactModalBtn" class="bg-primary hover:bg-opacity-90 text-background-dark text-sm font-bold py-2 px-4 rounded-lg transition-all flex items-center gap-2 cursor-pointer">
      <span class="material-symbols-outlined text-[18px]">calendar_month</span>
      <span>Contáctame</span>
    </button>
  </div>
</header>
