---
const jobs = [
  {
    active: true,
    icon: "work",
    title: "Desarrollador Full Stack Laravel",
    company: "MiEmpeño",
    period: "Febrero 2024 – Enero 2026",
    description: [
      {
        title: "IA & Automatización de ventas",
        items: [
          "Diseñé un agente de ventas conversacional vía WhatsApp con IA, capaz de gestionar hasta 30 usuarios simultáneos, calificar leads y cerrar ventas sin intervención humana.",
          "Migré el sistema de ChatGPT Completions a Threads API, reduciendo el consumo de tokens y costos operativos, con impacto directo en ~10 cierres diarios.",
          "Reemplacé procesos manuales con flujos asíncronos y colas de trabajo, eliminando cuellos de botella en atención al cliente.",
        ],
      },
      {
        title: "Integración Mercado Libre API",
        items: [
          "Construí un sistema multi-cuenta para gestión centralizada de publicaciones en Mercado Libre, con notificaciones automáticas en tiempo real.",
          "Automaticé la atención de preguntas vía WhatsApp: los vendedores responden con un reply y la respuesta se publica directamente en la plataforma sin iniciar sesión.",
          "Integré un agente que aprende de las respuestas del vendedor para resolver preguntas frecuentes de forma autónoma, reduciendo tiempos de respuesta entre un 50–75%.",
        ],
      },
      {
        title: "Infraestructura & Sistemas",
        items: [
          "Lideré la migración completa de AWS a GCP garantizando integridad de datos y continuidad operativa sin pérdidas.",
          "Mantuve y escalé 3 proyectos en producción: API de empeño/compra, calculadora de oro con lógica de peso y kilataje, y landing pages con análisis de flujo de conversión.",
          "Implementé soporte multilingüe en el sistema de chat en vivo para atención a usuarios internacionales.",
          "Desarrollé un sistema de seguimiento de recolecciones en tiempo real con notificaciones al cliente y al repartidor.",
        ],
      },
    ],
  },
  {
    active: false,
    icon: "code",
    title: "Desarrollador Full Stack (Becario)",
    company: "Hello México",
    period: "Agosto 2022 – Diciembre 2023",
    description: [
      {
        title: "Proyectos & contribuciones",
        items: [
          "Lideré el desarrollo de Dinero Inmediato desde cero: Product Backlog, wireframes y arquitectura del sistema.",
          "Construí la plataforma Full Stack con Laravel 8 + Livewire, integrando pagos recurrentes mediante OpenPay.",
          "Diseñé una solución automatizada para procesamiento masivo de datos en Excel, eliminando validaciones manuales.",
          "Administré el ciclo de vida de apps en DigitalOcean, Heroku y HostGator, incluyendo despliegues y respaldos críticos.",
          "Colaboré en equipo bajo metodología Scrum: Sprint Planning, pruebas y entregas iterativas.",
        ],
      },
    ],
  },
];
---

<div class="col-span-1 md:col-span-3 rounded-2xl bg-card-dark border border-border-dark p-6 md:p-8 flex flex-col relative overflow-hidden">
  <div class="flex items-center justify-between mb-8 z-10">
    <div>
      <h3 class="text-2xl font-bold text-white mb-1">Trayectoria Profesional</h3>
      <p class="text-text-muted text-sm">3+ años de experiencia</p>
    </div>
  </div>
  <div class="relative flex flex-col gap-0 z-10 h-full max-w-5xl">
    {
      jobs.map((job, index) => (
        <div class="relative flex gap-6 pb-12 group">
          {/* Línea conectora vertical */}
          <div class:list={["absolute left-5 top-0 w-0.5 bg-linear-to-b", job.active ? "h-full from-primary to-primary/20" : "h-16 from-primary/20 to-transparent"]} />

          {/* Icono circular */}
          <div
            class:list={[
              "relative z-10 mt-1.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border-2 bg-background-dark",
              job.active ? "border-primary shadow-[0_0_15px_rgba(19,236,109,0.3)]" : "border-border-dark group-hover:border-primary/50 transition-colors",
            ]}
          >
            <span class:list={["material-symbols-outlined text-[20px]", job.active ? "text-primary" : "text-text-muted group-hover:text-primary transition-colors"]}>{job.icon}</span>
          </div>

          {/* Contenido */}
          <div class="flex flex-col pt-1 w-full">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-2">
              <div>
                <h4 class:list={["text-lg font-bold text-white transition-colors", job.active ? "group-hover:text-primary" : "group-hover:text-white"]}>{job.title}</h4>
                <p class="text-sm font-medium text-text-muted">{job.company}</p>
              </div>
              <span
                class:list={[
                  "inline-flex w-fit items-center rounded-full px-2.5 py-0.5 text-xs",
                  job.active ? "bg-primary/10 font-bold text-primary border border-primary/20" : "bg-border-dark font-medium text-text-muted",
                ]}
              >
                {job.period}
              </span>
            </div>
            <div class="text-sm text-text-muted/80 leading-relaxed mb-4 max-w-4xl space-y-4">
              {job.description.map((block) =>
                typeof block === "string" ? (
                  <p>{block}</p>
                ) : (
                  <div>
                    <p>{block.title}</p>
                    <ul class="list-disc pl-5 mt-1 space-y-1 text-white/80">
                      {block.items.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                ),
              )}
            </div>
            <button class="open-contact-modal flex items-center gap-2 px-3 py-1.5 rounded bg-white/5 border border-white/10 hover:bg-white/10 hover:border-primary/30 transition-all w-fit group/btn hover:cursor-pointer">
              <span class="material-symbols-outlined text-text-muted text-[16px] group-hover/btn:text-primary">description</span>
              <span class="text-xs font-medium text-text-muted group-hover/btn:text-white">Ver Carta de Recomendación</span>
            </button>
          </div>
        </div>
      ))
    }
  </div>
</div>
